# ══════════════════════════════════════════════════════════════════
# LangNeurons — Environment Variables Template
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file — it is git-ignored.
#
#   cp .env.example .env
#
# ══════════════════════════════════════════════════════════════════


# ── Redis (required for agent memory + session persistence) ───────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                        # leave blank if no auth required


# ── LLM Provider ──────────────────────────────────────────────────
# Set ONE of: moonshot | openrouter | openai | anthropic | google | bedrock
LLM_PROVIDER=moonshot


# ── Moonshot Kimi (default — supports thinking mode) ─────────────
MOONSHOT_API_KEY=sk-...
MODEL_ROUTER_MOONSHOT=kimi-k2.5
MODEL_EXEC_MOONSHOT=kimi-k2.5
MODEL_VISION_MOONSHOT=moonshot-v1-8k-vision-preview
VISION_MODEL=moonshot-v1-8k-vision-preview


# ── OpenRouter (access 100+ models via single API) ────────────────
OPENROUTER_API_KEY=sk-or-v1-...
MODEL_ROUTER_OPENROUTER=deepseek/deepseek-chat
MODEL_EXEC_OPENROUTER=deepseek/deepseek-chat
OPENROUTER_APP_TITLE=LangNeurons      # optional, shown in dashboard


# ── OpenAI / GPT ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
MODEL_OPENAI_ROUTER=gpt-4o-mini
MODEL_OPENAI=gpt-4o


# ── Anthropic Claude ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL_ANTHROPIC_ROUTER=claude-3-haiku-20240307
MODEL_ANTHROPIC=claude-sonnet-4-5


# ── Google Gemini ─────────────────────────────────────────────────
GEMINI_API=AIza...
MODEL_GEMINI_ROUTER=gemini-2.5-flash
MODEL_GEMINI=gemini-2.5-pro


# ── Amazon Bedrock ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
MODEL_ROUTER_BEDROCK=anthropic.claude-3-haiku-20240307-v1:0
MODEL_EXEC_BEDROCK=anthropic.claude-3-5-sonnet-20241022-v2:0


# ── Web Search (for researcher agents) ────────────────────────────
TAVILY_API_KEY=tvly-...


# ── Memory Thresholds (optional — auto-scales if left blank) ──────
# MEMORY_RAW_THRESHOLD=20
# MEMORY_MEDIUM_THRESHOLD=40
# MEMORY_DECAY_BATCH_SIZE=10


# ── Debug ─────────────────────────────────────────────────────────
# LANGNEURONS_VERBOSE=1              # prints tool assignments per agent at startup
