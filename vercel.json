{
  "version": 2,
  "name": "langneurons",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/ws/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/js/:path*",
      "destination": "/frontend/static/js/:path*"
    },
    {
      "source": "/login",
      "destination": "/frontend/static/login.html"
    },
    {
      "source": "/console",
      "destination": "/frontend/static/console.html"
    },
    {
      "source": "/docs",
      "destination": "/frontend/static/docs.html"
    },
    {
      "source": "/blog",
      "destination": "/frontend/static/blog.html"
    },
    {
      "source": "/ecosystem",
      "destination": "/frontend/static/ecosystem.html"
    },
    {
      "source": "/integrations",
      "destination": "/frontend/static/integrations.html"
    },
    {
      "source": "/privacy",
      "destination": "/frontend/static/privacy.html"
    },
    {
      "source": "/product",
      "destination": "/frontend/static/product.html"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/static/:path*"
    }
  ]
}
